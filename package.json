{
  "name": "tt_logs",
  "version": "1.0.0",
  "description": "",
  "main": "parser.js",
  "type": "module",
  "scripts": {
    "build": "esbuild src/app.js --bundle --outfile=out.js",
    "build:watch": "esbuild src/app.js --bundle --outfile=out.js --servedir=.",
    "check": "npm run lint && npm test -- --runInBand && npm run test:video && npm run test:e2e:counter",
    "capture:evaluation": "python3 scripts/capture_evaluation.py",
    "counter": "python3 scripts/live_counter_server.py",
    "evaluate:detector": "python3 scripts/evaluate_detector.py",
    "counter:quest": "python3 scripts/live_counter_server.py 'srt://192.168.1.197:9000?mode=caller&latency=120000' --host 0.0.0.0",
    "counter:quest:debug": "npm run counter:quest -- --clean-recording artifacts/live-counter-clean.mkv --clean-recording-seconds 45 --live-events artifacts/live-counter-events.jsonl",
    "counter:replay": "python3 scripts/live_counter_replay.py test/fixtures/sample2-live-counter.json",
    "console": "node src/stats.js",
    "deploy": "./bin/deploy.sh",
    "lint": "eslint src/*.js test/*.js",
    "label:evaluation": "python3 scripts/label_evaluation.py",
    "prettier": "prettier src/*.js test/*.js --write",
    "test": "jest ./test/",
    "test:e2e:counter": "playwright test e2e/live-counter.spec.js",
    "test:e2e:counter:sample": "playwright test e2e/live-counter-sample.spec.js --config playwright.sample.config.js",
    "test:video": "python3 -m unittest test/video_source_test.py test/auto_calibration_test.py test/video_detector_unit_test.py test/live_counter_replay_test.py test/capture_evaluation_test.py test/label_evaluation_test.py test/evaluate_detector_test.py test/review_mismatches_test.py",
    "test:watch": "jest --watch ./test/"
  },
  "author": "Jacob",
  "license": "ISC",
  "dependencies": {
    "heatmap.js": "^2.0.5",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "esbuild": "^0.19.11",
    "esbuild-jest": "^0.5.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "pyright": "^1.1.411"
  }
}
